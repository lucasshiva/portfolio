  },
  "devDependencies": {
    "@iconify/json": "^2.2.481",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.9.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
